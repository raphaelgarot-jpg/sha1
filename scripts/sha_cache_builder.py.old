#!/usr/bin/env python3
import json
import time
import requests
import re
import os
from concurrent.futures import ThreadPoolExecutor, as_completed

# --- CONFIGURATION ---
CONF_FILE = "/var/www/html/sha/config/home_structure.conf"
RAM_FILE = "/dev/shm/sha_live.json"
TIMEOUT = 1.5 # Secondes max avant d'abandonner un Tasmota hors ligne

#deprecated, on utilise désormais fetch_device qui gère à la fois Tasmota et Shelly
def fetch_tasmota(ip):
    """Interroge un Tasmota spécifique pour récupérer sa puissance"""
    url = f"http://{ip}/cm?cmnd=Status%208"
    try:
        r = requests.get(url, timeout=TIMEOUT)
        r.raise_for_status()
        data = r.json()
        
        # On isole la section StatusSNS
        sns = data.get('StatusSNS', {})
        
        # 1. Prise Tasmota classique
        if 'ENERGY' in sns:
            power = sns['ENERGY'].get('Power', 0)
        # 2. Compteur principal (Verteiler type GS303)
        elif 'GS303' in sns:
            power = sns['GS303'].get('Power_cur', 0)
        # 3. Inconnu ou autre format
        else:
            power = 0
            
        return ip, power
    except Exception:
        # En cas d'erreur (débranché, pas de wifi), on retourne 0
        return ip, 0 
    
def fetch_device(ip):
    """Interroge un appareil (Tasmota ou Shelly) pour récupérer sa puissance"""
    
    # --- 1. Tentative Tasmota ---
    try:
        r = requests.get(f"http://{ip}/cm?cmnd=Status%208", timeout=TIMEOUT)
        if r.status_code == 200:
            data = r.json()
            sns = data.get('StatusSNS', {})
            if 'ENERGY' in sns: return ip, sns['ENERGY'].get('Power', 0)
            if 'GS303' in sns: return ip, sns['GS303'].get('Power_cur', 0)
    except Exception:
        pass # Si ce n'est pas un Tasmota ou erreur réseau, on passe à la suite

    # --- 2. Tentative Shelly (Gen 1 - ex: Shelly Plug S, 1PM) ---
    try:
        r = requests.get(f"http://{ip}/status", timeout=TIMEOUT)
        if r.status_code == 200:
            data = r.json()
            if 'meters' in data and len(data['meters']) > 0:
                return ip, data['meters'][0].get('power', 0)
    except Exception:
        pass

    # --- 3. Tentative Shelly (Gen 2 & Gen 3 - ex: Shelly Plus, Pro, Mini G3) ---
    try:
        r = requests.get(f"http://{ip}/rpc/Shelly.GetStatus", timeout=TIMEOUT)
        if r.status_code == 200:
            data = r.json()
            
            # Variante A : C'est un micromodule classique avec relais (switch)
            if 'switch:0' in data:
                return ip, data['switch:0'].get('apower', 0)
                
            # Variante B : C'est un moniteur de puissance pur (comme ton Mini PM G3)
            elif 'pm1:0' in data:
                return ip, data['pm1:0'].get('apower', 0)
    except Exception:
        pass

    # Si l'appareil est injoignable ou d'une marque inconnue
    return ip, 0

def build_cache():
    start_time = time.time()
    tasmota_ips = set()

    # 1. Extraction ultra-rapide des IPs depuis le fichier de conf
    try:
        with open(CONF_FILE, 'r') as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith(';'): continue
                
                # Récupère les compteurs System (ip_verteiler..., ip_solar...)
                if line.startswith('ip_verteiler') or line.startswith('ip_solar'):
                    match = re.search(r'"([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)"', line)
                    if match: tasmota_ips.add(match.group(1))
                
                # Récupère les appareils (devices[] = "socket|192.168...")
                elif line.startswith('devices[]'):
                    parts = line.split('|')
                    if len(parts) >= 2:
                        ip = parts[1]
                        # On pourrait filtrer ici, mais c'est aussi bien de tout mettre en cache
                        tasmota_ips.add(ip)
    except FileNotFoundError:
        print("Erreur : Fichier de configuration introuvable.")
        return

    # 2. Polling Concurant (Multithreading)
    live_data = {
        "devices": {},
        "timestamp": time.time()
    }
    
    # max_workers=30 signifie que Python peut interroger jusqu'à 30 appareils en même temps
    with ThreadPoolExecutor(max_workers=30) as executor:
        # On lance toutes les requêtes en parallèle
        #future_to_ip = {executor.submit(fetch_tasmota, ip): ip for ip in tasmota_ips}
        future_to_ip = {executor.submit(fetch_device, ip): ip for ip in tasmota_ips}

        # On récolte les résultats au fur et à mesure qu'ils arrivent
        for future in as_completed(future_to_ip):
            ip, power = future.result()
            live_data["devices"][ip] = power

    # 3. Écriture atomique en RAM
    # On écrit dans un fichier temporaire puis on le renomme.
    # Cela évite que PHP essaie de lire le fichier pendant qu'il est en cours d'écriture.
    temp_file = RAM_FILE + ".tmp"
    with open(temp_file, 'w') as f:
        json.dump(live_data, f)
    
    os.replace(temp_file, RAM_FILE)

    # Compte rendu en console
    elapsed = time.time() - start_time
    print(f"⚡ Cache RAM généré en {elapsed:.2f}s pour {len(tasmota_ips)} appareils.")

def run_worker():
    print("🚀 Démarrage du Worker S.H.A. en arrière-plan...")
    while True:
        build_cache()
        time.sleep(10) # Pause de 10 secondes entre chaque scan


if __name__ == "__main__":
    run_worker()
